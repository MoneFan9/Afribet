{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "rootDir": "static/src",
    "outDir": "static/dist",
    "removeComments": false
  },
  "include": ["static/src/**/*.ts"]
}
