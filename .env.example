# AfriBet — exemple de configuration d'environnement (copier vers .env)
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me-0123456789-abcdefghijklmnopqrstuvwxyz
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données : AFRIBET_DB=postgres pour utiliser Postgres (Docker/prod) ;
# absent ou "sqlite" => repli SQLite local (tests, vérif rapide).
# (En Docker, docker-compose fixe AFRIBET_DB=postgres pour web/worker.)
# AFRIBET_DB=postgres

# PostgreSQL (utilisé uniquement si AFRIBET_DB=postgres)
POSTGRES_DB=afribet
POSTGRES_USER=afribet
POSTGRES_PASSWORD=afribet
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (Channels + Celery)
REDIS_URL=redis://redis:6379/0

# Devise interne par défaut (objet-valeur Money)
AFRIBET_DEFAULT_CURRENCY=XAF
